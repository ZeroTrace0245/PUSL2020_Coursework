@{
    ViewData["Title"] = "Home";
}

<style>
    .site-tip-bar {
        background: rgba(255,255,255,0.95);
        border: 1px solid rgba(15,23,42,0.08);
        box-shadow: 0 18px 36px rgba(15,23,42,0.08);
        border-radius: 18px;
        text-align: center;
    }

    .hero-section {
        background: linear-gradient(135deg, #eff6ff 0%, #f8fafc 35%, #ffffff 100%);
        border-radius: 32px;
        padding: 3rem 0;
        margin-bottom: 3rem;
        position: relative;
        overflow: hidden;
    }

    .hero-section::before {
        content: '';
        position: absolute;
        right: -80px;
        top: -80px;
        width: 420px;
        height: 420px;
        border-radius: 50%;
        background: radial-gradient(circle at center, rgba(59,130,246,0.12), transparent 55%);
    }

    .hero-section::after {
        content: '';
        position: absolute;
        left: -80px;
        bottom: -80px;
        width: 360px;
        height: 360px;
        border-radius: 50%;
        background: radial-gradient(circle at center, rgba(16,185,129,0.10), transparent 55%);
    }

    .hero-title {
        font-size: clamp(2.5rem, 4vw, 3.6rem);
        line-height: 1.02;
        font-weight: 800;
        margin-bottom: 1rem;
        color: #0f172a;
        margin-left: auto;
        margin-right: auto;
    }

    .hero-subtitle {
        font-size: 1.15rem;
        line-height: 1.8;
        color: #475569;
        margin-bottom: 2rem;
        max-width: 680px;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
    }

    .home-hero-card {
        background: rgba(255,255,255,0.88);
        border: 1px solid rgba(15,23,42,0.06);
        box-shadow: 0 28px 70px rgba(15,23,42,0.09);
        border-radius: 28px;
        text-align: center;
    }

    .home-hero-card h3 {
        font-size: 1.6rem;
        font-weight: 800;
        margin-bottom: 1rem;
    }

    .home-hero-card ul {
        padding-left: 1.2rem;
        color: #334155;
        list-style: none;
        display: inline-block;
        text-align: left;
    }

    .home-hero-card ul li {
        position: relative;
        padding-left: 1.6rem;
        margin-bottom: 1rem;
    }

    .home-hero-card ul li::before {
        content: "\f00c";
        font-family: "Font Awesome 6 Free";
        font-weight: 900;
        position: absolute;
        left: 0;
        top: 0.05rem;
        color: #2563eb;
    }

    .feature-card {
        background: rgba(255,255,255,0.96);
        border: 1px solid rgba(15,23,42,0.08);
        border-radius: 24px;
        padding: 2rem;
        text-align: center;
        box-shadow: 0 24px 64px rgba(15,23,42,0.08);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .feature-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 28px 75px rgba(15,23,42,0.12);
    }

    .feature-icon {
        font-size: 2rem;
        color: #2563eb;
        margin-bottom: 1rem;
    }

    .feature-title {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
        color: #0f172a;
    }

    .feature-text,
    .hero-tip-text,
    .section-copy {
        color: #475569;
        line-height: 1.8;
    }

    .cta-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 2rem;
        justify-content: center;
    }

    .btn-cta {
        border-radius: 999px;
        padding: 0.95rem 1.9rem;
        font-weight: 700;
        box-shadow: 0 16px 30px rgba(37,99,235,0.18);
    }

    .btn-cta-primary {
        background: linear-gradient(135deg, #2563eb 0%, #38bdf8 100%);
        color: white;
        border: none;
    }

    .btn-cta-secondary {
        border: 1px solid rgba(15,23,42,0.12);
        background: white;
        color: #0f172a;
    }

    .section-title {
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 1rem;
    }

    .section-copy {
        font-size: 1rem;
        margin-bottom: 2rem;
    }

    .feature-list-group {
        gap: 1rem;
    }

    .feature-list-box {
        background: rgba(255,255,255,0.95);
        border: 1px solid rgba(15,23,42,0.08);
        border-radius: 22px;
        padding: 1.8rem;
        height: 100%;
        text-align: center;
    }

    .feature-list-box h5 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: #0f172a;
    }

    .feature-list-box p {
        color: #475569;
    }

    body.theme-dark .site-tip-bar,
    body.theme-dark .hero-section,
    body.theme-dark .home-hero-card,
    body.theme-dark .feature-card,
    body.theme-dark .feature-list-box {
        background: rgba(15, 23, 42, 0.88);
        border-color: rgba(148, 163, 184, 0.22);
        box-shadow: 0 24px 60px rgba(2, 6, 23, 0.45);
    }

    body.theme-dark .hero-title,
    body.theme-dark .feature-title,
    body.theme-dark .section-title,
    body.theme-dark .home-hero-card h3,
    body.theme-dark .feature-list-box h5,
    body.theme-dark .hero-subtitle,
    body.theme-dark .feature-text,
    body.theme-dark .hero-tip-text,
    body.theme-dark .section-copy,
    body.theme-dark .home-hero-card ul,
    body.theme-dark .feature-list-box p {
        color: #f8fafc !important;
    }

    body.theme-dark .btn-cta-secondary {
        background: rgba(30, 41, 59, 0.95);
        border-color: rgba(148, 163, 184, 0.22);
        color: #f8fafc;
    }

    body.theme-dark .badge.bg-secondary {
        background-color: #1d4ed8 !important;
    }

    body.theme-dark .hero-section::before {
        background: radial-gradient(circle at center, rgba(59,130,246,0.18), transparent 55%);
    }

    body.theme-dark .hero-section::after {
        background: radial-gradient(circle at center, rgba(14,165,233,0.16), transparent 55%);
    }

    @@media (max-width: 991px) {
        .hero-section {
            padding: 2.5rem 0;
        }

        .hero-title {
            font-size: 2.4rem;
        }

        .home-hero-card {
            margin-top: 1.5rem;
        }
    }
</style>

<div class="container">
    <div class="site-tip-bar p-3 mb-4 d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
        <div>
            <h6 class="mb-1 fw-bold text-primary">Quick tip for first-time users</h6>
            <p class="mb-0 hero-tip-text">Use the supervisor expertise settings and research-area filters before browsing projects to get the most relevant matches.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 justify-content-center">
            <span class="badge bg-primary rounded-pill py-2 px-3">Modern UX</span>
            <span class="badge bg-secondary rounded-pill py-2 px-3">Secure</span>
            <span class="badge bg-secondary rounded-pill py-2 px-3">Inclusive</span>
        </div>
    </div>
</div>

<div class="hero-section">
    <div class="container-lg">
        <div class="row align-items-center gx-5 justify-content-center text-center">
            <div class="col-lg-7">
                <h1 class="hero-title">A modern academic matching platform for fair project allocation.</h1>
                <p class="hero-subtitle">Blind-Match PAS removes bias from the supervision process by letting supervisors review proposals anonymously, while giving students clear status updates and matched contact details once approved.</p>
                <div class="cta-buttons">
                    <a href="/Account/Register?userType=Student" class="btn btn-cta btn-cta-primary"><i class="fas fa-user-graduate me-2"></i> Register as Student</a>
                    <a href="/Account/Register?userType=Supervisor" class="btn btn-cta btn-cta-primary"><i class="fas fa-chalkboard-user me-2"></i> Register as Supervisor</a>
                    <a href="/Account/Login" class="btn btn-cta btn-cta-secondary"><i class="fas fa-sign-in-alt me-2"></i> Login</a>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="home-hero-card p-4">
                    <span class="badge bg-primary text-white rounded-pill py-2 px-3 mb-3 d-inline-flex align-items-center"><i class="fas fa-lightbulb me-2"></i> Professional academic workflow</span>
                    <h3 class="mb-3">Designed for clarity and control</h3>
                    <ul>
                        <li>Anonymous proposal browsing for supervisors</li>
                        <li>Clear project status tracking for students</li>
                        <li>Admin oversight with research-area management</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row g-4 feature-list-group justify-content-center text-center">
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
                <h3 class="feature-title">Secure Roles</h3>
                <p class="feature-text">Students, supervisors, module leaders and admins each have tailored access for safer workflows.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon"><i class="fas fa-mask"></i></div>
                <h3 class="feature-title">Blind Matching</h3>
                <p class="feature-text">Supervisor decisions are based on technical merit and research fit, not student identity.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon"><i class="fas fa-chart-pie"></i></div>
                <h3 class="feature-title">Allocation Insights</h3>
                <p class="feature-text">Monitor matches, pending projects, and active research areas from a polished admin dashboard.</p>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row gx-5 justify-content-center text-center">
        <div class="col-lg-6">
            <div class="feature-list-box">
                <h5>Student-focused workflow</h5>
                <p>Submit project proposals easily, track your approval status, and see supervisor details only after the match is confirmed.</p>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="feature-list-box">
                <h5>Supervisor review engine</h5>
                <p>Set your expertise areas, search only relevant ideas, and express interest confidentially before confirming a match.</p>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="text-center mb-4">
        <h2 class="section-title">A professional academic platform</h2>
        <p class="section-copy">Built for universities, Blind-Match PAS streamlines projects while preserving fairness and transparency.</p>
    </div>
    <div class="row g-4 justify-content-center text-center">
        <div class="col-md-4">
            <div class="feature-list-box">
                <h5>Reduce administrative overhead</h5>
                <p>Automate matching workflows and let module leaders intervene only when needed.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-list-box">
                <h5>Improve match quality</h5>
                <p>Match based on expertise alignment and technical merit, not student name or affiliation.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-list-box">
                <h5>Modern academic UX</h5>
                <p>Enjoy a clean interface with crisp cards, rounded panels, and clear call-to-action buttons.</p>
            </div>
        </div>
    </div>
</div>

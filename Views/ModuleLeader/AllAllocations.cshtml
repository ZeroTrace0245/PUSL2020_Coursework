@model List<PUSL2020_Coursework.ViewModels.MatchDetailViewModel>

@{
    ViewData["Title"] = "All Allocations";
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var totalMatches = (int)ViewBag.TotalMatches;
}

<div class="container">
    <h2>All Project Allocations</h2>
    <p class="text-muted">Total Matches: @totalMatches | Page @currentPage of @totalPages</p>

    @if (!Model.Any())
    {
        <div class="alert alert-info mt-4">
            <p>No allocations yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive mt-4">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Project Title</th>
                        <th>Student</th>
                        <th>Supervisor</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var match in Model)
                    {
                        <tr>
                            <td>
                                <strong>@match.ProjectTitle</strong>
                            </td>
                            <td>@match.StudentName</td>
                            <td>@match.SupervisorName</td>
                            <td>
                                <span class="badge @(match.Status == "Confirmed" ? "bg-success" : match.Status == "Interested" ? "bg-info" : match.Status == "Rejected" ? "bg-danger" : "bg-warning")">
                                    @match.Status
                                </span>
                            </td>
                            <td>@match.CreatedDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a href="/ModuleLeader/ProjectDetails/@match.ProjectId" class="btn btn-sm btn-primary">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <nav>
                <ul class="pagination justify-content-center">
                    @if (currentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/ModuleLeader/AllAllocations?page=1">First</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="/ModuleLeader/AllAllocations?page=@(currentPage - 1)">Previous</a>
                        </li>
                    }

                    @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="/ModuleLeader/AllAllocations?page=@i">@i</a>
                        </li>
                    }

                    @if (currentPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/ModuleLeader/AllAllocations?page=@(currentPage + 1)">Next</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="/ModuleLeader/AllAllocations?page=@totalPages">Last</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>

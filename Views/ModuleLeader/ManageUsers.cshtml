@model List<PUSL2020_Coursework.ViewModels.UserManagementViewModel>

@{
    ViewData["Title"] = "Manage Users";
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var totalUsers = (int)ViewBag.TotalUsers;
}

<div class="container">
    <h2>Manage Users</h2>
    <p class="text-muted">Total Users: @totalUsers | Page @currentPage of @totalPages</p>

    @if (!Model.Any())
    {
        <div class="alert alert-info mt-4">
            <p>No users found.</p>
        </div>
    }
    else
    {
        <div class="table-responsive mt-4">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Roles</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.FirstName @user.LastName</td>
                            <td>@user.Email</td>
                            <td>@(user.Department ?? "-")</td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    <span class="badge bg-info">@role</span>
                                }
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td>@user.CreatedDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <form method="post" asp-action="DeactivateUser" asp-route-userId="@user.Id" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-warning">Deactivate</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-action="ActivateUser" asp-route-userId="@user.Id" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success">Activate</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <nav>
                <ul class="pagination justify-content-center">
                    @if (currentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/ModuleLeader/ManageUsers?page=1">First</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="/ModuleLeader/ManageUsers?page=@(currentPage - 1)">Previous</a>
                        </li>
                    }

                    @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="/ModuleLeader/ManageUsers?page=@i">@i</a>
                        </li>
                    }

                    @if (currentPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/ModuleLeader/ManageUsers?page=@(currentPage + 1)">Next</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="/ModuleLeader/ManageUsers?page=@totalPages">Last</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>

@model List<PUSL2020_Coursework.ViewModels.BlindProjectViewModel>

@{
    ViewData["Title"] = "Browse Projects";
    var expertiseAreas = ViewBag.ExpertiseAreas as IEnumerable<PUSL2020_Coursework.Models.SupervisorExpertise>
        ?? Enumerable.Empty<PUSL2020_Coursework.Models.SupervisorExpertise>();
    var selectedAreaId = (int)ViewBag.SelectedAreaId;
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var totalProjects = (int)ViewBag.TotalProjects;
}

<div class="container">
    <h2>Browse Projects</h2>
    <p class="text-muted">All projects are displayed anonymously. Student identity will be revealed only upon match confirmation.</p>

    <div class="row mt-4">
        <div class="col-md-3">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Filter by Area</h5>
                </div>
                <div class="card-body">
                    <form method="get" asp-action="BrowseProjects">
                        <div class="mb-3">
                            <select name="areaId" class="form-select" onchange="this.form.submit()">
                                <option value="0">-- All Areas --</option>
                                @foreach (var expertise in expertiseAreas)
                                {
                                    <option value="@expertise.ResearchAreaId" selected="@(expertise.ResearchAreaId == selectedAreaId)">
                                        @expertise.ResearchArea?.Name
                                    </option>
                                }
                            </select>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col-md-8">
                            <h5 class="mb-0">Available Projects (@totalProjects)</h5>
                        </div>
                        <div class="col-md-4 text-end">
                            <small class="text-muted">Page @currentPage of @totalPages</small>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    @if (!Model.Any())
                    {
                        <div class="alert alert-info">
                            <p>No projects available in your expertise areas at this time.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var project in Model)
                        {
                            <div class="card project-card mb-3">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-8">
                                            <h5 class="card-title project-card-title">@project.Title</h5>
                                            <p class="card-text">
                                                <small class="text-muted">@project.ResearchArea • Submitted @project.SubmittedDate.ToString("dd/MM/yyyy")</small>
                                            </p>
                                            <p class="card-text">
                                                @project.Abstract.Substring(0, Math.Min(150, project.Abstract.Length))...
                                            </p>
                                            <p class="card-text">
                                                <strong>Tech Stack:</strong> @project.TechnicalStack
                                            </p>
                                        </div>
                                        <div class="col-md-4 text-end">
                                            @if (project.HasExpressedInterest)
                                            {
                                                <span class="badge bg-success mb-2">Interested</span>
                                            }
                                            else
                                            {
                                                <form method="post" asp-action="ExpressInterest" asp-route-projectId="@project.Id" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-primary">Express Interest</button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }

                    @if (totalPages > 1)
                    {
                        <nav>
                            <ul class="pagination justify-content-center">
                                @if (currentPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="/SupervisorDashboard/BrowseProjects?areaId=@selectedAreaId&page=1">First</a>
                                    </li>
                                    <li class="page-item">
                                        <a class="page-link" href="/SupervisorDashboard/BrowseProjects?areaId=@selectedAreaId&page=@(currentPage - 1)">Previous</a>
                                    </li>
                                }

                                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                                {
                                    <li class="page-item @(i == currentPage ? "active" : "")">
                                        <a class="page-link" href="/SupervisorDashboard/BrowseProjects?areaId=@selectedAreaId&page=@i">@i</a>
                                    </li>
                                }

                                @if (currentPage < totalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="/SupervisorDashboard/BrowseProjects?areaId=@selectedAreaId&page=@(currentPage + 1)">Next</a>
                                    </li>
                                    <li class="page-item">
                                        <a class="page-link" href="/SupervisorDashboard/BrowseProjects?areaId=@selectedAreaId&page=@totalPages">Last</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blind-Match Project Approval System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --bg: #f5f7ff;
            --bg-layer: rgba(255, 255, 255, 0.72);
            --surface: rgba(255, 255, 255, 0.92);
            --surface-strong: rgba(255, 255, 255, 0.98);
            --border: rgba(15, 23, 42, 0.12);
            --primary: #0f172a;
            --secondary: #2563eb;
            --secondary-soft: #dbeafe;
            --accent: #2563eb;
            --success: #16a34a;
            --warning: #d97706;
            --danger: #dc2626;
            --text: #0f172a;
            --muted: #64748b;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            min-height: 100%;
        }

        body {
            font-family: 'Segoe UI Variable', 'Segoe UI', Inter, system-ui, sans-serif;
            background: radial-gradient(circle at top left, rgba(37, 99, 235, 0.12), transparent 20%),
                        radial-gradient(circle at bottom right, rgba(37, 99, 235, 0.08), transparent 15%),
                        var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        body.theme-dark {
            --bg: #0b1220;
            --bg-layer: rgba(15, 23, 42, 0.72);
            --surface: rgba(15, 23, 42, 0.88);
            --surface-strong: rgba(2, 6, 23, 0.98);
            --border: rgba(148, 163, 184, 0.22);
            --primary: #f8fafc;
            --secondary: #60a5fa;
            --secondary-soft: rgba(37, 99, 235, 0.25);
            --accent: #93c5fd;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --text: #f8fafc;
            --muted: #cbd5e1;
        }

        body.theme-dark {
            background: radial-gradient(circle at top left, rgba(59, 130, 246, 0.16), transparent 24%),
                        radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.14), transparent 22%),
                        var(--bg);
        }

        .navbar {
            background: rgba(255, 255, 255, 0.78);
            backdrop-filter: blur(24px);
            border-bottom: 1px solid var(--border);
            box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .navbar .container-fluid {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.9rem 1.2rem;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
        }

        .navbar-brand i {
            color: var(--secondary);
        }

        .navbar-brand:hover {
            transform: translateY(-1px);
            transition: transform 0.2s ease;
        }

        .nav-link {
            color: rgba(15, 23, 42, 0.7) !important;
            font-weight: 600;
            margin: 0 0.4rem;
            transition: color 0.2s ease, transform 0.2s ease;
            text-decoration: none;
            white-space: nowrap;
        }

        .theme-toggle-btn {
            border-radius: 999px;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--primary);
            padding: 0.45rem 0.85rem;
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            font-weight: 700;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .theme-toggle-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.15);
        }

        .navbar-collapse {
            display: flex;
            flex: 1;
            justify-content: flex-end;
        }

        .navbar-nav {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            align-items: center;
            list-style: none;
            margin: 0;
            padding: 0;
            gap: 0.2rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
        }

        .navbar-toggler {
            display: none;
        }

        .nav-link:hover,
        .nav-link.active {
            color: var(--secondary) !important;
            transform: translateY(-1px);
        }

        .container-main {
            flex: 1;
            margin: 2.5rem auto;
            padding: 0 2rem;
            width: min(1200px, 100%);
        }

        .card {
            border: 1px solid var(--border);
            border-radius: 28px;
            background: var(--surface);
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
            transition: transform 0.25s ease, box-shadow 0.25s ease;
            overflow: hidden;
        }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 30px 70px rgba(15, 23, 42, 0.12);
        }

        .card-header {
            background: rgba(248, 250, 252, 0.95);
            color: var(--primary);
            border-bottom: 1px solid rgba(15, 23, 42, 0.08);
            font-weight: 700;
            padding: 1.6rem 2rem;
        }

        .card-body {
            padding: 2rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--secondary), #60a5fa);
            border: none;
            color: white;
            font-weight: 700;
            border-radius: 999px;
            padding: 0.88rem 1.85rem;
            box-shadow: 0 18px 28px rgba(37, 99, 235, 0.18);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 22px 34px rgba(37, 99, 235, 0.22);
        }

        .btn-secondary,
        .btn-outline-secondary {
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid rgba(15, 23, 42, 0.12);
            color: var(--primary);
            font-weight: 700;
            border-radius: 999px;
        }

        .btn-secondary:hover,
        .btn-outline-secondary:hover {
            background: rgba(241, 245, 249, 0.95);
            color: var(--primary);
        }

        .btn-success,
        .btn-danger,
        .btn-warning {
            border-radius: 999px;
            font-weight: 700;
        }

        .btn-success { background-color: var(--success); color: white; }
        .btn-warning { background-color: var(--warning); color: white; }
        .btn-danger { background-color: var(--danger); color: white; }

        .badge-status {
            padding: 0.65rem 1rem;
            border-radius: 999px;
            font-weight: 700;
            font-size: 0.85rem;
        }

        .status-pending { background: #fde68a; color: #92400e; }
        .status-underreview { background: #bfdbfe; color: #1d4ed8; }
        .status-matched { background: #86efac; color: #14532d; }
        .status-withdrawn { background: #e2e8f0; color: #334155; }

        .alert-custom {
            border-radius: 22px;
            border: 1px solid rgba(15, 23, 42, 0.08);
            box-shadow: 0 18px 42px rgba(15, 23, 42, 0.08);
        }

        .alert-success { background: #ecfdf5; color: #166534; border-left: 4px solid #22c55e; }
        .alert-danger { background: #fef2f2; color: #991b1b; border-left: 4px solid #ef4444; }

        @@keyframes slideInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .dashboard-stat,
        .project-card,
        .card {
            animation: fadeIn 0.35s ease forwards;
        }

        .dashboard-stat {
            background: var(--surface);
            border-radius: 24px;
            padding: 2rem;
            text-align: center;
            box-shadow: 0 20px 48px rgba(15, 23, 42, 0.08);
            border: 1px solid rgba(15, 23, 42, 0.08);
        }

        .dashboard-stat:hover { transform: translateY(-4px); }
        .dashboard-stat-value { font-size: 3rem; font-weight: 800; color: var(--secondary); }
        .dashboard-stat-label { color: var(--muted); font-weight: 700; margin-top: 0.5rem; }

        .project-card {
            background: var(--surface);
            border-radius: 24px;
            border: 1px solid rgba(15, 23, 42, 0.08);
            padding: 1.75rem;
            margin-bottom: 1rem;
        }

        .project-card:hover { transform: translateY(-3px); box-shadow: 0 20px 45px rgba(15, 23, 42, 0.1); }
        .project-card-title { font-weight: 800; color: var(--primary); font-size: 1.2rem; }

        footer {
            background: var(--surface);
            color: var(--primary);
            padding: 2rem 0;
            margin-top: auto;
            border-top: 1px solid rgba(15, 23, 42, 0.08);
            text-align: center;
        }

        footer p { margin: 0.35rem 0; opacity: 0.85; }
        footer p strong { color: var(--secondary); }

        .table {
            background: var(--surface);
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 18px 42px rgba(15, 23, 42, 0.08);
        }

        .table thead { background: rgba(37, 99, 235, 0.12); color: var(--primary); font-weight: 700; }
        .table tbody tr:hover { background-color: rgba(37, 99, 235, 0.08); }

        .form-control,
        .form-select {
            border-radius: 18px;
            border: 1px solid rgba(15, 23, 42, 0.12);
            padding: 1rem 1.1rem;
            font-weight: 500;
            background: rgba(255, 255, 255, 0.96);
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: rgba(37, 99, 235, 0.65);
            box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.14);
        }

        .form-check-input {
            width: 1.25rem;
            height: 1.25rem;
            border-radius: 0.55rem;
            border: 1px solid rgba(15, 23, 42, 0.18);
        }

        .form-check-input:checked {
            background-color: var(--secondary);
            border-color: var(--secondary);
            box-shadow: 0 2px 8px rgba(37, 99, 235, 0.2);
        }

        .pagination { gap: 0.5rem; }
        .page-link {
            border-radius: 999px;
            border: 1px solid rgba(15, 23, 42, 0.12);
            color: var(--primary);
            font-weight: 700;
        }

        .page-link:hover {
            background-color: rgba(37, 99, 235, 0.1);
            border-color: rgba(37, 99, 235, 0.35);
            color: var(--secondary);
        }

        .page-item.active .page-link {
            background-color: var(--secondary);
            border-color: var(--secondary);
            color: white;
            box-shadow: 0 14px 28px rgba(37, 99, 235, 0.18);
        }

        @@media (max-width: 768px) {
            .navbar .container-fluid {
                flex-direction: column;
                align-items: flex-start;
            }

            .navbar-collapse {
                width: 100%;
                justify-content: flex-start;
            }

            .navbar-nav {
                width: 100%;
                gap: 0.1rem;
            }

            .container-main {
                margin-top: 1.5rem;
                margin-bottom: 1.5rem;
                padding: 0 1rem;
            }

            .dashboard-stat-value { font-size: 2.3rem; }
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .jumbotron {
            background: rgba(255, 255, 255, 0.95);
            color: var(--primary);
            border-radius: 24px;
            padding: 3rem 2rem;
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.1);
        }

        .jumbotron h1 {
            font-weight: 900;
            font-size: 2.8rem;
        }

        .jumbotron p {
            font-size: 1.05rem;
            color: var(--muted);
        }

        .list-group-item {
            border: 1px solid rgba(15, 23, 42, 0.12);
            border-radius: 18px;
            margin-bottom: 0.75rem;
            background: rgba(255, 255, 255, 0.95);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .list-group-item:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 38px rgba(15, 23, 42, 0.08);
            border-color: rgba(37, 99, 235, 0.22);
        }

        body.theme-dark .navbar {
            background: rgba(2, 6, 23, 0.74);
            box-shadow: 0 18px 50px rgba(2, 6, 23, 0.45);
        }

        body.theme-dark .nav-link {
            color: rgba(248, 250, 252, 0.82) !important;
        }

        body.theme-dark .nav-link:hover,
        body.theme-dark .nav-link.active {
            color: #93c5fd !important;
        }

        body.theme-dark .card,
        body.theme-dark .project-card,
        body.theme-dark .dashboard-stat,
        body.theme-dark .table,
        body.theme-dark .list-group-item,
        body.theme-dark footer {
            background: var(--surface);
            border-color: var(--border);
            color: var(--text);
        }

        body.theme-dark .table thead {
            background: rgba(30, 41, 59, 0.85);
            color: var(--text);
        }

        body.theme-dark .table tbody tr:hover {
            background-color: rgba(37, 99, 235, 0.2);
        }

        body.theme-dark .form-control,
        body.theme-dark .form-select {
            background: rgba(15, 23, 42, 0.78);
            color: var(--text);
            border-color: var(--border);
        }

        body.theme-dark .form-control::placeholder {
            color: var(--muted);
        }

        body.theme-dark .card-header {
            background: rgba(30, 41, 59, 0.92) !important;
            color: #f8fafc !important;
            border-bottom: 1px solid var(--border);
        }

        body.theme-dark .dashboard-stat-label,
        body.theme-dark .text-muted,
        body.theme-dark footer p,
        body.theme-dark small {
            color: var(--muted) !important;
        }

        body.theme-dark .card-title,
        body.theme-dark .project-card-title,
        body.theme-dark h1,
        body.theme-dark h2,
        body.theme-dark h3,
        body.theme-dark h4,
        body.theme-dark h5,
        body.theme-dark h6,
        body.theme-dark p,
        body.theme-dark li,
        body.theme-dark label,
        body.theme-dark strong,
        body.theme-dark span,
        body.theme-dark a {
            color: var(--text);
        }

        body.theme-dark .btn-secondary,
        body.theme-dark .btn-outline-secondary {
            background: rgba(30, 41, 59, 0.85);
            border-color: var(--border);
            color: var(--text);
        }

        body.theme-dark .btn-secondary:hover,
        body.theme-dark .btn-outline-secondary:hover {
            background: rgba(51, 65, 85, 0.95);
            color: var(--text);
        }

        body.theme-dark .alert-danger {
            background: rgba(127, 29, 29, 0.35) !important;
            color: #fecaca !important;
            border-left: 4px solid #ef4444;
            border-color: rgba(239, 68, 68, 0.45);
        }

        body.theme-dark .alert-danger * {
            color: #fecaca !important;
        }

        body.theme-dark .alert-success {
            background: rgba(20, 83, 45, 0.35) !important;
            color: #bbf7d0 !important;
            border-left: 4px solid #22c55e;
            border-color: rgba(34, 197, 94, 0.45);
        }

        body.theme-dark .alert-success * {
            color: #bbf7d0 !important;
        }

        body.theme-dark .text-danger,
        body.theme-dark .field-validation-error,
        body.theme-dark .validation-summary-errors,
        body.theme-dark .validation-summary-errors li {
            color: #fda4af !important;
        }
    </style>
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="fas fa-graduation-cap"></i>
                Blind-Match PAS
            </a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <button type="button" id="themeToggle" class="theme-toggle-btn" title="Toggle theme">
                            <i class="fas fa-moon" id="themeToggleIcon"></i>
                            <span id="themeToggleText">Dark</span>
                        </button>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-home"></i> Home</a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/StudentProjects/Index"><i class="fas fa-project-diagram"></i> My Projects</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/StudentProjects/Create"><i class="fas fa-plus"></i> Submit Project</a>
                            </li>
                        }
                        @if (User.IsInRole("Supervisor"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/SupervisorDashboard/Index"><i class="fas fa-chart-line"></i> Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/SupervisorDashboard/BrowseProjects"><i class="fas fa-search"></i> Browse</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/SupervisorDashboard/MyMatches"><i class="fas fa-handshake"></i> Matches</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/SupervisorDashboard/ManageExpertise"><i class="fas fa-cog"></i> Expertise</a>
                            </li>
                        }
                        @if (User.IsInRole("ModuleLeader"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/ModuleLeader/Dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/ModuleLeader/AllAllocations"><i class="fas fa-list"></i> Allocations</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/ModuleLeader/ManageResearchAreas"><i class="fas fa-tag"></i> Areas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/ModuleLeader/ManageUsers"><i class="fas fa-users"></i> Users</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Admin/Dashboard"><i class="fas fa-lock"></i> Admin</a>
                            </li>
                        }
                        <li class="nav-item">
                            <div class="nav-link">
                                <i class="fas fa-user-circle"></i> @User.Identity?.Name
                            </div>
                        </li>
                        <li class="nav-item">
                            <form method="post" action="/Account/Logout" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light btn-sm ms-2">
                                    <i class="fas fa-sign-out-alt"></i> Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login"><i class="fas fa-sign-in-alt"></i> Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Register"><i class="fas fa-user-plus"></i> Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="container-main container-lg">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-custom alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-custom alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer>
        <div class="container">
            <p><strong>Blind-Match Project Approval System</strong></p>
            <p>© 2024 All rights reserved. Secure. Fair. Merit-Based.</p>
            <p><small>Ensuring unbiased project allocation through technology</small></p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            var body = document.body;
            var toggle = document.getElementById('themeToggle');
            var icon = document.getElementById('themeToggleIcon');
            var text = document.getElementById('themeToggleText');
            if (!toggle || !icon || !text) return;

            var savedTheme = localStorage.getItem('pas-theme');
            if (savedTheme === 'dark') {
                body.classList.add('theme-dark');
            }

            function syncToggleUi() {
                var dark = body.classList.contains('theme-dark');
                icon.className = dark ? 'fas fa-sun' : 'fas fa-moon';
                text.textContent = dark ? 'Light' : 'Dark';
                toggle.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
            }

            syncToggleUi();

            toggle.addEventListener('click', function () {
                body.classList.toggle('theme-dark');
                localStorage.setItem('pas-theme', body.classList.contains('theme-dark') ? 'dark' : 'light');
                syncToggleUi();
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

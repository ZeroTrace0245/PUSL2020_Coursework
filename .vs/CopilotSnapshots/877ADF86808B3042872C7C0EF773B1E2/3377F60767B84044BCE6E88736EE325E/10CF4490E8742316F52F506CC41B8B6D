@{
    ViewData["Title"] = "Home";
}

<div class="container">
    @if (!User.Identity?.IsAuthenticated ?? true)
    {
        <div class="row">
            <div class="col-md-12">
                <div class="jumbotron bg-light p-5 rounded-lg">
                    <h1 class="display-4">Welcome to Blind-Match PAS</h1>
                    <p class="lead">A secure, web-based Project Approval System facilitating fair matching of student research projects with academic supervisors.</p>
                    <hr class="my-4">
                    <p>Our system prioritizes <strong>Blind Matching</strong> to ensure project selection based on technical merit and area alignment, eliminating unconscious bias.</p>
                    <div class="mt-4">
                        <a class="btn btn-primary btn-lg me-2" href="/Account/Register?userType=Student" role="button">Register as Student</a>
                        <a class="btn btn-secondary btn-lg me-2" href="/Account/Register?userType=Supervisor" role="button">Register as Supervisor</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-5">
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title">🎓 For Students</h5>
                        <p class="card-text">Submit your innovative research ideas and get matched with experienced supervisors.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title">👨‍🏫 For Supervisors</h5>
                        <p class="card-text">Browse projects anonymously, express interest, and confirm matches based on merit.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title">📊 For Administrators</h5>
                        <p class="card-text">Manage allocations, oversee the process, and ensure fair distribution.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-5">
            <div class="col-md-12">
                <h3>Key Features</h3>
                <ul class="list-group">
                    <li class="list-group-item">✅ Secure Role-Based Access Control</li>
                    <li class="list-group-item">✅ Anonymous Project Browsing for Supervisors</li>
                    <li class="list-group-item">✅ Identity Reveal Upon Confirmation</li>
                    <li class="list-group-item">✅ Research Area Management</li>
                    <li class="list-group-item">✅ Comprehensive Allocation Dashboard</li>
                    <li class="list-group-item">✅ Group Project Support</li>
                </ul>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-12">
                <h2>Welcome, @User.Identity?.Name!</h2>
                <p class="text-muted">Select an option from the navigation menu to proceed.</p>
            </div>
        </div>

        @if (User.IsInRole("Student"))
        {
            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">My Projects</h5>
                            <p class="card-text">View and manage your submitted research proposals.</p>
                            <a href="/StudentProjects/Index" class="btn btn-primary">Go to My Projects</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Submit New Project</h5>
                            <p class="card-text">Create a new research proposal for supervisor review.</p>
                            <a href="/StudentProjects/Create" class="btn btn-primary">Submit Project</a>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (User.IsInRole("Supervisor"))
        {
            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Browse Projects</h5>
                            <p class="card-text">Explore anonymous projects matching your expertise.</p>
                            <a href="/SupervisorDashboard/BrowseProjects" class="btn btn-primary">Browse</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">My Matches</h5>
                            <p class="card-text">View and manage your project interests and confirmations.</p>
                            <a href="/SupervisorDashboard/MyMatches" class="btn btn-primary">View Matches</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row mt-3">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">⚙️ Manage Expertise</h5>
                            <p class="card-text">Update your research area preferences to filter relevant projects.</p>
                            <a href="/SupervisorDashboard/ManageExpertise" class="btn btn-primary">Manage</a>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (User.IsInRole("ModuleLeader"))
        {
            <div class="row mt-4">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Dashboard</h5>
                            <p class="card-text">View allocation overview and statistics.</p>
                            <a href="/ModuleLeader/Dashboard" class="btn btn-primary">View</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">All Allocations</h5>
                            <p class="card-text">Review and manage all project-supervisor matches.</p>
                            <a href="/ModuleLeader/AllAllocations" class="btn btn-primary">View</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Research Areas</h5>
                            <p class="card-text">Manage available research categories.</p>
                            <a href="/ModuleLeader/ManageResearchAreas" class="btn btn-primary">Manage</a>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (User.IsInRole("Admin"))
        {
            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">System Dashboard</h5>
                            <p class="card-text">View system statistics and manage roles.</p>
                            <a href="/Admin/Dashboard" class="btn btn-primary">Go to Dashboard</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Create Users</h5>
                            <p class="card-text">Create admin and module leader accounts.</p>
                            <a href="/Admin/CreateAdmin" class="btn btn-primary">Create</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
    .jumbotron {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .card {
        transition: transform 0.3s;
    }

    .card:hover {
        transform: translateY(-5px);
    }
</style>
